{
  "name": "super-opencode",
  "version": "1.0.0",
  "description": "Portage complet de SuperClaude vers OpenCode - installable framework pourProductivité developer.",
  "author": "SuperClaude Community",
  "license": "MIT",
  "homepage": "https://github.com/superclaude/super-opencode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/superclaude/super-opencode.git"
  },
  "keywords": [
    "opencode",
    "ai",
    "productivity",
    "framework",
    "superclaude",
    "cli"
  ],
  "type": "module",
  "packageManager": "bun@1.3.9",
  "main": ".opencode/plugins/super-opencode.ts",
  "exports": {
    ".": ".opencode/plugins/super-opencode.ts",
    "./commands": ".opencode/commands/",
    "./agents": ".opencode/agents/",
    "./skills": ".opencode/skills/"
  },
  "files": [
    ".opencode/**/*",
    "docs/**/*.md"
  ],
  "scripts": {
    "check": "bun run validate:structure && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "validate:structure": "node scripts/validate-structure.mjs",
    "install:project": "bun run scripts/install-project.mjs",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "echo 'Linting not configured yet' && exit 1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.4.0"
  }
}
