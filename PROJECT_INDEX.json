{
  "name": "super-opencode-framework",
  "version": "1.0.1",
  "kind": "opencode-framework-plugin",
  "summary": "OpenCode plugin package with a server runtime, a TUI plugin, and a manifest-driven bootstrap engine that syncs Super OpenCode commands, agents, skills, and instructions into project or global scope.",
