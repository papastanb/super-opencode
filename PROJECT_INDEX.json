    "commands": 28,
    "agents": 15,
    "skills": 6,
    "testFiles": 2,
    "testCases": 33,
    "scripts": 4,
    "githubWorkflows": 2
  },
  "entrypoints": [
    {
      "path": "src/server.ts",
      "kind": "server-plugin",
      "exports": ["default", "SuperOpenCodePlugin"]
    },
    {
      "path": "src/tui.ts",
      "kind": "tui-plugin",
      "exports": ["default"]
    },
    {
      "path": "src/cli.ts",
      "kind": "cli-module",
      "exports": ["runCli"]
    },
    {
      "path": "scripts/install-project.mjs",
